{
  "name": "manifest",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/manifest/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/packages/manifest",
        "main": "packages/manifest/src/index.ts",
        "tsConfig": "packages/manifest/tsconfig.lib.json",
        "assets": ["packages/manifest/*.md"]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/vite:test",
      "outputs": ["{workspaceRoot}/coverage/packages/manifest"],
      "options": {
        "passWithNoTests": true,
        "reportsDirectory": "../../coverage/packages/manifest"
      }
    }
  },
  "tags": ["type:package"]
}
